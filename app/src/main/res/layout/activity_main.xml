<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_home_logo"
                android:layout_marginBottom="16dp"
                android:elevation="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Rs"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:textColor="@android:color/white" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hisaab"
                android:textStyle="bold"
                android:textSize="30sp"
                android:letterSpacing="-0.02"
                android:textColor="@color/home_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your daily expenses"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:textColor="@color/home_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_home_card"
            android:padding="18dp"
            android:layout_marginBottom="24dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs 12,450"
                    android:textStyle="bold"
                    android:textSize="19sp"
                    android:textColor="@color/home_text_primary"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="19sp"
                    android:autoSizeStepGranularity="1sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This month"
                    android:textAllCaps="true"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/home_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#F0F0F5" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs 820"
                    android:textStyle="bold"
                    android:textSize="19sp"
                    android:textColor="@color/home_text_primary"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="19sp"
                    android:autoSizeStepGranularity="1sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textAllCaps="true"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/home_text_muted" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#F0F0F5" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="23"
                    android:textStyle="bold"
                    android:textSize="19sp"
                    android:textColor="@color/home_text_primary"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="19sp"
                    android:autoSizeStepGranularity="1sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entries"
                    android:textAllCaps="true"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/home_text_muted" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categories"
            android:textAllCaps="true"
            android:textSize="12sp"
            android:letterSpacing="0.18"
            android:textStyle="bold"
            android:textColor="@color/home_text_muted"
            android:layout_marginBottom="14dp"
            android:paddingStart="4dp" />

        <androidx.gridlayout.widget.GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:columnCount="2"
            app:rowCount="4"
            app:alignmentMode="alignMargins"
            app:useDefaultMargins="true">

            <LinearLayout
                android:id="@+id/cardMilk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnSpan="1"
                app:layout_rowSpan="1"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_home_card"
                android:paddingTop="0dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="top"
                    android:background="#FFFF9800" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_icon"
                    android:backgroundTint="#FFFFF3E0"
                    android:gravity="center"
                    android:text="&#x1F95B;"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FFFF9800" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Milk"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/home_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnSpan="1"
                app:layout_rowSpan="1"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_home_card"
                android:paddingTop="0dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="top"
                    android:background="#FF5C6BC0" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_icon"
                    android:backgroundTint="#FFE8EAF6"
                    android:gravity="center"
                    android:text="&#x1F3E0;"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FF5C6BC0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Rent"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/home_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnSpan="1"
                app:layout_rowSpan="1"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_home_card"
                android:paddingTop="0dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="top"
                    android:background="#FFFBC02D" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_icon"
                    android:backgroundTint="#FFFFF9C4"
                    android:gravity="center"
                    android:text="&#x26A1;"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FFFBC02D" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Electricity"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/home_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnSpan="1"
                app:layout_rowSpan="1"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_home_card"
                android:paddingTop="0dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="top"
                    android:background="#FF66BB6A" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_icon"
                    android:backgroundTint="#FFE8F5E9"
                    android:gravity="center"
                    android:text="&#x1F6D2;"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FF66BB6A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Groceries"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/home_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnSpan="1"
                app:layout_rowSpan="1"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_home_card"
                android:paddingTop="0dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="top"
                    android:background="#FF8BC34A" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_icon"
                    android:backgroundTint="#FFF1F8E9"
                    android:gravity="center"
                    android:text="&#x1F96C;"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FF8BC34A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Vegetables"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/home_text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_columnSpan="1"
                app:layout_rowSpan="1"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_home_card"
                android:paddingTop="0dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="top"
                    android:background="#FF42A5F5" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_icon"
                    android:backgroundTint="#FFE3F2FD"
                    android:gravity="center"
                    android:text="&#x1F697;"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FF42A5F5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Travel"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/home_text_secondary" />
            </LinearLayout>

        </androidx.gridlayout.widget.GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hisaab"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/home_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" - Smart Expense Tracking"
                android:textSize="12sp"
                android:textColor="@color/home_text_muted" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
