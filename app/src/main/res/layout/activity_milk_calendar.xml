<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/milk_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_toolbar"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_toolbar_btn"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="&#x1F95B; Milk Calendar"
            android:textColor="@android:color/white"
            android:textSize="19sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_toolbar_btn"
            android:src="@drawable/setting"
            android:tint="@android:color/white" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/milk_container"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_light"
                android:padding="10dp"
                android:elevation="2dp">

                <ImageButton
                    android:id="@+id/btnPrev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_nav_button"
                    android:src="@android:drawable/ic_media_rew"
                    android:tint="@color/accent"/>

                <TextView
                    android:id="@+id/tvMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="March 2026"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:background="@drawable/bg_nav_button"
                    android:tint="@color/accent" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp">

                <TextView style="@style/dayHeader" android:text="Sun"/>
                <TextView style="@style/dayHeader" android:text="Mon"/>
                <TextView style="@style/dayHeader" android:text="Tue"/>
                <TextView style="@style/dayHeader" android:text="Wed"/>
                <TextView style="@style/dayHeader" android:text="Thu"/>
                <TextView style="@style/dayHeader" android:text="Fri"/>
                <TextView style="@style/dayHeader" android:text="Sat"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_card_light"
                android:padding="8dp"
                android:elevation="2dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/calendarRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:padding="2dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_light"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4CA; Legend"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/legend_paid" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Paid and taken"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/legend_unpaid" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Unpaid and taken"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/legend_not_taken" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Not taken"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/legend_no_entry" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="No entry"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_light"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:elevation="3dp">

                <TextView
                    android:id="@+id/tvSummaryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="March 2026 Summary"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#FFF3E5F5"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_stat_box">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#x1F4C5;"
                            android:textSize="22sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Days taken"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvDaysTaken"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="12sp"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeStepGranularity="1sp"
                            android:maxLines="1" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_stat_box">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#x1F95B;"
                            android:textSize="22sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total liters"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvTotalLiters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="12sp"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeStepGranularity="1sp"
                            android:maxLines="1" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_stat_box">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#x1F4B0;"
                            android:textSize="22sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amount spent"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/tvTotalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs 0"
                            android:textColor="@color/accent"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginTop="4dp"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="12sp"
                            android:autoSizeMaxTextSize="20sp"
                            android:autoSizeStepGranularity="1sp"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnAddToday"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="&#xFF0B; Add Today's Milk Entry"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_button_primary" />

                <Button
                    android:id="@+id/btnViewEntries"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="&#x1F4CB; View All Entries"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_button_secondary" />

                <Button
                    android:id="@+id/btnClearAll"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="&#x1F5D1; Clear All Data"
                    android:textColor="#FFD32F2F"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_button_danger" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
